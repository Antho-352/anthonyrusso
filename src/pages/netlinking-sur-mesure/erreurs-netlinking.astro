</style>

<script>
  // Quiz logic
  const quiz = document.getElementById('quiz')!;
  const submitBtn = document.getElementById('quizSubmit') as HTMLButtonElement;
  const resultsDiv = document.getElementById('quizResults')!;
  const resultScore = document.getElementById('resultScore')!;
  const resultTitle = document.getElementById('resultTitle')!;
  const resultText = document.getElementById('resultText')!;
  const resetBtn = document.getElementById('quizReset')!;

  const totalQuestions = 5;
  let answeredQuestions = new Set<string>();

  // Check if all questions are answered
  function checkCompletion() {
    const allInputs = quiz.querySelectorAll('input[type="radio"]');
    answeredQuestions.clear();

    allInputs.forEach((input) => {
      const radio = input as HTMLInputElement;
      if (radio.checked) {
        answeredQuestions.add(radio.name);
      }
    });

    submitBtn.disabled = answeredQuestions.size !== totalQuestions;
  }

  // Add listeners to all radio inputs
  const radioInputs = quiz.querySelectorAll('input[type="radio"]');
  radioInputs.forEach((input) => {
    input.addEventListener('change', checkCompletion);
  });

  // Calculate score and show results
  submitBtn.addEventListener('click', () => {
    let score = 0;

    for (let i = 1; i <= totalQuestions; i++) {
      const selected = quiz.querySelector(`input[name="q${i}"]:checked`) as HTMLInputElement;
      if (selected) {
        score += parseInt(selected.value);
      }
    }

    // Show results
    resultScore.textContent = score.toString();

    if (score <= 1) {
      resultTitle.textContent = "Profil probablement sain";
      resultText.textContent = "Votre profil présente peu de signaux d'alerte. Continuez à monitorer régulièrement votre acquisition de liens et à travailler avec méthode.";
      resultScore.style.color = 'var(--color-success)';
    } else if (score <= 3) {
      resultTitle.textContent = "Des points méritent attention";
      resultText.textContent = "Votre profil présente quelques signaux qui méritent vérification. Un audit de contrôle permettrait d'identifier précisément les zones à corriger avant qu'elles deviennent problématiques.";
      resultScore.style.color = '#FFC107';
    } else {
      resultTitle.textContent = "Audit urgent recommandé";
      resultText.textContent = "Votre profil présente des risques réels. Un audit complet s'impose pour identifier les erreurs actuelles, évaluer leur impact, et construire une stratégie de correction avant que la situation se dégrade davantage.";
      resultScore.style.color = 'var(--color-error)';
    }

    // Hide questions, show results
    quiz.querySelectorAll('.quiz-question').forEach((q) => {
      (q as HTMLElement).style.display = 'none';
    });
    submitBtn.style.display = 'none';
    resultsDiv.classList.remove('hidden');

    // Scroll to results
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  // Reset quiz
  resetBtn.addEventListener('click', () => {
    // Reset all inputs
    radioInputs.forEach((input) => {
      (input as HTMLInputElement).checked = false;
    });

    // Reset UI
    answeredQuestions.clear();
    submitBtn.disabled = true;
    resultsDiv.classList.add('hidden');
    quiz.querySelectorAll('.quiz-question').forEach((q) => {
      (q as HTMLElement).style.display = 'block';
    });
    submitBtn.style.display = 'block';

    // Scroll back to quiz
    quiz.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>

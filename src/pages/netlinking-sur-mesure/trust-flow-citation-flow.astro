    margin-bottom: var(--space-md);
    font-weight: 700;
  }

  .content-section p {
    margin-bottom: var(--space-lg);
    line-height: 1.75;
  }

  .content-section ul {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
  }

  .content-section li {
    margin-bottom: var(--space-sm);
  }

  .content-section a {
    color: var(--color-primary);
    text-decoration: underline;

    padding: 2px 6px;
    border-radius: var(--radius-sm);
    font-size: 0.875em;
  }

  /* Content sections */
  .content-section {
    margin-bottom: var(--space-3xl);
  }

  .content-section h2 {
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
  }

  .content-section h3 {
    font-size: 1.25rem;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    font-weight: 700;
  }

  .content-section p {
    margin-bottom: var(--space-lg);
    line-height: 1.75;
  }

  .content-section ul {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
  }

  .content-section li {

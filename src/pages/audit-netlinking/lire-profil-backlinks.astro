<script>
  // Interactive checklist functionality
  const form = document.getElementById('backlink-health-checklist') as HTMLFormElement;
  const resultDiv = document.getElementById('checklist-result') as HTMLDivElement;
  const checkboxes = form.querySelectorAll('input[type="checkbox"]');

  function updateResult() {
    const checkedCount = Array.from(checkboxes).filter((cb: HTMLInputElement) => cb.checked).length;

    if (checkedCount === 0) {
      resultDiv.style.display = 'none';
      return;
    }

    resultDiv.style.display = 'block';

    if (checkedCount < 5) {
      resultDiv.className = 'checklist-result warning';
      resultDiv.innerHTML = `
        <p>Score : ${checkedCount}/8 — Un audit s'impose</p>
        <p style="font-size: 0.9375rem; font-weight: 400; margin-top: var(--space-md);">
          Votre profil présente des signaux de risque ou d'opportunités non exploitées.
          Un audit complet permet d'identifier les priorités et de construire un plan d'action sur mesure.
        </p>
        <a href="/audit-netlinking/">Demander un audit netlinking</a>
      `;
    } else {
      resultDiv.className = 'checklist-result good';
      resultDiv.innerHTML = `
        <p>Score : ${checkedCount}/8 — Profil ${checkedCount === 8 ? 'excellent' : 'sain'}</p>
        <p style="font-size: 0.9375rem; font-weight: 400; margin-top: var(--space-md);">
          ${checkedCount === 8
            ? 'Votre profil respecte les bonnes pratiques essentielles. Continuez ce monitoring régulier.'
            : 'Votre profil est globalement sain. Les points non cochés méritent une attention particulière lors du prochain audit.'}
        </p>
      `;
    }
  }

  checkboxes.forEach((checkbox) => {
    checkbox.addEventListener('change', updateResult);
  });
</script>

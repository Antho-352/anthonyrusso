      font-size: 0.875rem;
    }

    .data-table th,
    .data-table td {
      padding: var(--space-sm);
    }
  }
</style>

<script>
  // Link Gap table functionality
  const tableBody = document.getElementById('table-body') as HTMLTableSectionElement;
  const addRowBtn = document.getElementById('add-row-btn') as HTMLButtonElement;
  const exportCsvBtn = document.getElementById('export-csv-btn') as HTMLButtonElement;

  // Add new row
  addRowBtn.addEventListener('click', () => {
    const newRow = document.createElement('tr');
    newRow.innerHTML = `
      <td contenteditable="true">nouveau-spot.fr</td>
      <td contenteditable="true">0</td>
      <td contenteditable="true">0/mois</td>
      <td contenteditable="true">0/5</td>
      <td contenteditable="true">-</td>
      <td contenteditable="true">-</td>
      <td class="priority-cell" data-priority="moyenne">🟡 Moyenne</td>
      <td><button class="btn-delete" onclick="deleteRow(this)">✕</button></td>
    `;
    tableBody.appendChild(newRow);
  });

  // Delete row function (global scope for inline onclick)
  (window as any).deleteRow = function(btn: HTMLButtonElement) {
    const row = btn.closest('tr');
    if (row && tableBody.children.length > 1) {
      row.remove();
    } else if (tableBody.children.length === 1) {
      alert('Le tableau doit contenir au moins une ligne.');
    }
  };

  // Export to CSV
  exportCsvBtn.addEventListener('click', () => {
    const table = document.getElementById('link-gap-table') as HTMLTableElement;
    const rows = table.querySelectorAll('tr');
    let csv = '';

    rows.forEach((row, index) => {
      const cells = row.querySelectorAll(index === 0 ? 'th' : 'td');
      const rowData: string[] = [];

      cells.forEach((cell, cellIndex) => {
        // Skip last column (delete button)
        if (cellIndex < cells.length - 1) {
          let cellText = cell.textContent?.trim() || '';
          // Escape quotes and wrap in quotes if contains comma
          if (cellText.includes(',') || cellText.includes('"') || cellText.includes('\n')) {
            cellText = '"' + cellText.replace(/"/g, '""') + '"';
          }
          rowData.push(cellText);
        }
      });

      csv += rowData.join(',') + '\n';
    });

    // Create download
    const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    const url = URL.createObjectURL(blob);
    link.setAttribute('href', url);
    link.setAttribute('download', 'link-gap-analysis.csv');
    link.style.visibility = 'hidden';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  });

  // Handle priority cell clicks to cycle through values
  tableBody.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains('priority-cell')) {
      const currentPriority = target.getAttribute('data-priority');
      if (currentPriority === 'haute') {
        target.setAttribute('data-priority', 'moyenne');
        target.textContent = '🟡 Moyenne';
      } else {
        target.setAttribute('data-priority', 'haute');
        target.textContent = '🟢 Haute';
      }
    }
  });
</script>

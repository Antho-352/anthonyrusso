    border-bottom: 2px solid var(--color-primary);
    white-space: nowrap;
  }

  .data-table td {
    padding: var(--space-md);
    color: var(--color-text);
    border-bottom: 1px solid var(--color-surface-3);
  }

  .data-table tbody tr:hover {
    background: var(--color-surface-2);
  }

  .data-table td[contenteditable="true"] {
    cursor: text;
  }

  .data-table td[contenteditable="true"]:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: -2px;
    background: var(--color-surface-3);
  }

  .priority-cell {
    font-weight: 600;
    white-space: nowrap;
  }

  .priority-cell[data-priority="haute"] {
    color: #03A388;
  }

  .priority-cell[data-priority="moyenne"] {
    color: #FF9500;
  }

  .btn-delete {
    background: transparent;
    border: none;
    color: var(--color-text-muted);
    font-size: 1.25rem;
    cursor: pointer;
    padding: var(--space-xs);
    line-height: 1;
    transition: color var(--transition-base);
  }

  .btn-delete:hover {
    color: #FF6B35;
  }

  .priority-legend {
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    background: var(--color-surface-1);
    border-radius: var(--radius-md);
    font-size: 0.9375rem;
  }

  .priority-legend p {
    margin-bottom: var(--space-sm);
  }

  .priority-legend p:first-child {
    font-weight: 700;
    margin-bottom: var(--space-md);
  }

  .priority-badge {
    display: inline-block;
    font-weight: 600;
  }

  .priority-badge.haute {
    color: #03A388;
  }

  .priority-badge.moyenne {
    color: #FF9500;
  }

  /* FAQ Section */
  .faq-section {
    margin-top: var(--space-3xl);
  }

  .faq-item {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-surface-3);
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-item h3 {
    color: var(--color-primary);
    font-size: 1.125rem;
    margin-bottom: var(--space-md);
  }

  .faq-item p {
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .evergreen-article {
      padding: var(--space-xl) var(--space-md);
    }

    .article-header h1 {
      font-size: 1.75rem;
    }

    h2 {
      font-size: 1.5rem;
    }

    .link-gap-tool {
      padding: var(--space-xl);
    }


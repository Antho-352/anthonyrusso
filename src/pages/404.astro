---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page introuvable"
  description="La page que vous cherchez n'existe pas. Profitez-en pour jouer à Attrape les backlinks !"
  noIndex={true}
>
  <div class="game-container">
    <div class="game-header">
      <h1>404 — Page introuvable</h1>
      <p class="subtitle">En attendant, attrape des backlinks 🔗</p>
    </div>

    <div class="game-ui">
      <div class="game-stats">
        <div class="stat">
          <span class="stat-label">Score</span>
          <span class="stat-value" id="score">0</span>
        </div>
        <div class="stat">
          <span class="stat-label">Vies</span>
          <span class="stat-value" id="lives">🔗🔗🔗</span>
        </div>
        <div class="stat">
          <span class="stat-label">Niveau</span>
          <span class="stat-value" id="level">1</span>
        </div>
      </div>

      <div class="game-canvas-wrapper">
        <canvas id="gameCanvas" width="800" height="500"></canvas>
        <div id="damageOverlay" class="damage-overlay"></div>
        <div id="scorePopups" class="score-popups"></div>

        <!-- Start overlay -->
        <div id="startOverlay" class="start-overlay">
          <div class="start-content">
            <button id="startBtn" class="btn-start">START</button>
            <p class="start-hint">Déplace l'épuisette avec ta souris</p>
          </div>
        </div>
      </div>

      <div class="game-instructions">
        <p><strong>🔗 Liens</strong> : Gros (+5) · Moyen (+10) · Petit (+20)</p>
        <p><strong>🟢 Bonus</strong> : +50 pts (rapide !)</p>
        <p><strong>⚠️ N'attrape pas les 404 et les SPAM !</strong></p>
      </div>
    </div>

    <!-- Game Over Overlay -->
    <div id="gameOverOverlay" class="overlay hidden">
      <div class="overlay-content">
        <h2>Game over !</h2>
        <p class="final-score">Score final : <span id="finalScore">0</span> pts</p>

        <form id="scoreForm" class="score-form">
          <input
            type="text"
            id="username"
            placeholder="Ton pseudo"
            maxlength="20"
            pattern="[a-zA-Z0-9_-]+"
            required
          />
          <button type="submit" class="btn-primary">Enregistrer mon score</button>
          <p id="formError" class="form-error hidden"></p>
        </form>

        <div class="overlay-actions">
          <button id="restartBtn" class="btn-secondary">Rejouer</button>
          <a href="/" class="btn-link">Retour à l'accueil</a>
        </div>

        <div class="leaderboard">
          <h3>Top 10</h3>
          <div id="leaderboardList" class="leaderboard-list">
            <p class="loading">Chargement...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .game-container {
    min-height: calc(100vh - 200px);
    padding: 2rem 1rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .game-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .game-header h1 {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
  }

  .game-ui {
    background: var(--color-surface-2);
    border-radius: 12px;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
  }

  .game-stats {
    display: flex;
    justify-content: space-around;
    margin-bottom: 1.5rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .stat {
    text-align: center;
  }

  .stat-label {
    display: block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .stat-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .game-canvas-wrapper {
    position: relative;
    margin-bottom: 1.5rem;
  }

  #gameCanvas {
    width: 100%;
    height: auto;
    background: var(--color-bg);
    border-radius: 8px;
    border: 2px solid var(--color-border);
    display: block;
    cursor: none;
  }

  .damage-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    border-radius: 8px;
    opacity: 0;
    transition: opacity 0.1s;
  }

  .damage-overlay.active {
    opacity: 1;
    box-shadow: inset 0 0 0 8px var(--color-error);
    animation: damageFlash 0.5s;
  }

  @keyframes damageFlash {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }

  .score-popups {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
  }

  .score-popup {
    position: absolute;
    font-size: 1.5rem;
    font-weight: 700;
    animation: popupFloat 1s ease-out forwards;
    pointer-events: none;
  }

  .score-popup.positive {
    color: var(--color-success);
  }

  .score-popup.negative {
    color: var(--color-error);
  }

  @keyframes popupFloat {
    0% {
      opacity: 1;
      transform: translateY(0);
    }
    100% {
      opacity: 0;
      transform: translateY(-40px);
    }
  }

  .start-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(2, 10, 50, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    z-index: 10;
  }

  .start-overlay.hidden {
    display: none;
  }

  .start-content {
    text-align: center;
  }

  .btn-start {
    padding: 1.5rem 3rem;
    font-size: 2rem;
    font-weight: 800;
    font-family: 'Cabinet Grotesk', sans-serif;
    background: var(--color-primary-cta);
    color: white;
    border-radius: 12px;
    transition: all 0.2s;
    cursor: pointer;
    margin-bottom: 1rem;
  }

  .btn-start:hover {
    background: var(--color-primary-hover);
    transform: scale(1.05);
  }

  .btn-start:active {
    transform: scale(0.95);
  }

  .start-hint {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .game-instructions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    background: var(--color-surface);
    border-radius: 8px;
    font-size: 0.875rem;
  }

  .game-instructions p {
    margin: 0;
    color: var(--color-text-muted);
  }

  .game-instructions strong {
    color: var(--color-text);
  }

  /* Overlay */
  .overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(2, 10, 50, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 1rem;
    backdrop-filter: blur(8px);
  }

  .overlay.hidden {
    display: none;
  }

  .overlay-content {
    background: var(--color-surface-2);
    border-radius: 16px;
    padding: 2rem;
    max-width: 500px;
    width: 100%;
    border: 1px solid var(--color-border);
  }

  .overlay-content h2 {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text);
    text-align: center;
    margin-bottom: 1rem;
  }

  .final-score {
    text-align: center;
    font-size: 1.5rem;
    color: var(--color-primary);
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .score-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .score-form input {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 1rem;
  }

  .score-form input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-highlight);
  }

  .btn-primary, .btn-secondary {
    padding: 0.875rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--color-primary-cta);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-surface-offset);
  }

  .btn-link {
    display: inline-block;
    padding: 0.875rem 1.5rem;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    text-decoration: underline;
  }

  .btn-link:hover {
    color: var(--color-text);
  }

  .form-error {
    color: var(--color-error);
    font-size: 0.875rem;
    text-align: center;
  }

  .form-error.hidden {
    display: none;
  }

  .overlay-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .leaderboard {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-divider);
  }

  .leaderboard h3 {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1rem;
    text-align: center;
  }

  .leaderboard-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .leaderboard-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border-radius: 6px;
    border: 1px solid transparent;
  }

  .leaderboard-item.highlight {
    border-color: var(--color-primary);
    background: var(--color-primary-highlight);
  }

  .leaderboard-rank {
    font-weight: 700;
    color: var(--color-primary);
    min-width: 2rem;
  }

  .leaderboard-username {
    flex: 1;
    color: var(--color-text);
  }

  .leaderboard-score {
    font-weight: 600;
    color: var(--color-success);
  }

  .leaderboard-date {
    font-size: 0.75rem;
    color: var(--color-text-faint);
    margin-left: 1rem;
  }

  .loading {
    text-align: center;
    color: var(--color-text-muted);
    padding: 2rem;
  }

  @media (max-width: 768px) {
    .game-container {
      padding: 1rem 0.5rem;
    }

    .game-ui {
      padding: 1rem;
    }

    .overlay-content {
      padding: 1.5rem;
    }

    .leaderboard-date {
      display: none;
    }
  }
</style>

<script>
  // Game state
  let score = 0;
  let lives = 3;
  let level = 1;
  let gameRunning = false;
  let elements: FallingElement[] = [];
  let lastSpawn = 0;
  let spawnInterval = 1200;
  let speedMultiplier = 1;
  let animationId: number;
  let netX = 400; // Center of net
  let mouseX = 400;

  // Canvas setup
  const canvas = document.getElementById('gameCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const damageOverlay = document.getElementById('damageOverlay')!;
  const scorePopups = document.getElementById('scorePopups')!;
  const startOverlay = document.getElementById('startOverlay')!;
  const startBtn = document.getElementById('startBtn')!;

  // UI elements
  const scoreEl = document.getElementById('score')!;
  const livesEl = document.getElementById('lives')!;
  const levelEl = document.getElementById('level')!;
  const gameOverOverlay = document.getElementById('gameOverOverlay')!;
  const finalScoreEl = document.getElementById('finalScore')!;
  const scoreForm = document.getElementById('scoreForm') as HTMLFormElement;
  const formError = document.getElementById('formError')!;
  const restartBtn = document.getElementById('restartBtn')!;
  const leaderboardList = document.getElementById('leaderboardList')!;

  // Net config
  const NET_WIDTH = canvas.width * 0.10; // 10% of screen width
  const NET_HEIGHT = 48; // Reduced by 20% from 60px
  const NET_Y = canvas.height - NET_HEIGHT - 10;

  // Element types
  type ElementType = 'link-big' | 'link-medium' | 'link-small' | 'bonus' | 'error-404' | 'spam';

  interface FallingElement {
    x: number;
    y: number;
    width: number;
    height: number;
    speed: number;
    type: ElementType;
    emoji?: string;
    text?: string;
    color: string;
    bgColor?: string;
    points: number;
  }

  const ELEMENT_CONFIGS = {
    'link-big': {
      emoji: '🔗',
      width: 40,
      height: 40,
      speedRange: [1.5, 2.5],
      points: 5,
      weight: 0.25,
      color: '#4C75FF',
    },
    'link-medium': {
      emoji: '🔗',
      width: 30,
      height: 30,
      speedRange: [2.5, 3.5],
      points: 10,
      weight: 0.30,
      color: '#4C75FF',
    },
    'link-small': {
      emoji: '🔗',
      width: 20,
      height: 20,
      speedRange: [4, 5.5],
      points: 20,
      weight: 0.20,
      color: '#4C75FF',
    },
    'bonus': {
      emoji: '🔗',
      text: '',
      width: 100,
      height: 28,
      speedRange: [6, 8],
      points: 50,
      weight: 0.10,
      color: '#fff',
      bgColor: '#03A388',
    },
    'error-404': {
      text: '404',
      width: 70,
      height: 28,
      speedRange: [5, 7],
      points: -20,
      weight: 0.10,
      color: '#fff',
      bgColor: '#CC3366',
    },
    'spam': {
      text: 'SPAM',
      width: 80,
      height: 28,
      speedRange: [6.5, 8.5],
      points: -10,
      weight: 0.05,
      color: '#fff',
      bgColor: '#FF6B35',
    },
  };

  // Initialize game
  function init() {
    score = 0;
    lives = 3;
    level = 1;
    elements = [];
    speedMultiplier = 1;
    gameRunning = false;
    lastSpawn = 0;
    netX = canvas.width / 2;

    updateUI();
    gameOverOverlay.classList.add('hidden');
    startOverlay.classList.remove('hidden');
    scorePopups.innerHTML = '';
    loadLeaderboard();
  }

  function startGame() {
    gameRunning = true;
    startOverlay.classList.add('hidden');
    gameLoop(0);
  }

  function gameLoop(timestamp: number) {
    if (!gameRunning) return;

    // Clear canvas
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Smooth net movement
    netX += (mouseX - netX) * 0.2;

    // Spawn new elements
    if (timestamp - lastSpawn > spawnInterval / speedMultiplier) {
      spawnElement();
      lastSpawn = timestamp;
    }

    // Update and draw elements
    for (let i = elements.length - 1; i >= 0; i--) {
      const el = elements[i];
      el.y += el.speed * speedMultiplier;

      // Check if caught by net
      if (el.y + el.height >= NET_Y && el.y + el.height <= NET_Y + NET_HEIGHT) {
        const elCenterX = el.x + el.width / 2;
        const netLeft = netX - NET_WIDTH / 2;
        const netRight = netX + NET_WIDTH / 2;

        if (elCenterX >= netLeft && elCenterX <= netRight) {
          // Element caught!
          score += el.points;
          if (el.points < 0 && el.type === 'error-404') {
            loseLife();
          }
          showScorePopup(el.x, el.y, el.points);
          elements.splice(i, 1);
          updateUI();
          continue;
        }
      }

      // Check if element passed the net (missed)
      if (el.y > canvas.height) {
        // Only lose life if it was a good link
        if (el.points > 0) {
          loseLife();
        }
        elements.splice(i, 1);
        continue;
      }

      // Draw element
      drawElement(el);
    }

    // Draw net
    drawNet();

    // Level up
    if (score > 0 && score % 150 === 0 && score !== level * 150) {
      levelUp();
    }

    animationId = requestAnimationFrame(gameLoop);
  }

  function spawnElement() {
    // Limit simultaneous elements
    if (elements.length >= 8) return;

    // Weighted random element type
    const rand = Math.random();
    let cumulative = 0;
    let type: ElementType = 'link-medium';

    for (const [key, config] of Object.entries(ELEMENT_CONFIGS)) {
      cumulative += config.weight;
      if (rand <= cumulative) {
        type = key as ElementType;
        break;
      }
    }

    const config = ELEMENT_CONFIGS[type];
    const x = Math.random() * (canvas.width - config.width);
    const speed = config.speedRange[0] + Math.random() * (config.speedRange[1] - config.speedRange[0]);

    elements.push({
      x,
      y: -config.height,
      width: config.width,
      height: config.height,
      speed,
      type,
      emoji: config.emoji,
      text: config.text,
      color: config.color,
      bgColor: config.bgColor,
      points: config.points,
    });
  }

  function drawElement(el: FallingElement) {
    if (el.bgColor) {
      // Box element (404, SPAM, bonus)
      ctx.shadowColor = 'rgba(0, 0, 0, 0.3)';
      ctx.shadowBlur = 6;
      ctx.shadowOffsetY = 3;

      ctx.fillStyle = el.bgColor;
      ctx.beginPath();
      ctx.roundRect(el.x, el.y, el.width, el.height, 4);
      ctx.fill();

      ctx.shadowColor = 'transparent';
      ctx.shadowBlur = 0;
      ctx.shadowOffsetY = 0;

      // Border
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.3)';
      ctx.lineWidth = 1;
      ctx.stroke();

      // Text or emoji
      ctx.fillStyle = el.color;
      if (el.text) {
        ctx.font = el.type === 'error-404' ? '700 16px Cabinet Grotesk' : '600 14px Satoshi';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(el.text, el.x + el.width / 2, el.y + el.height / 2);
      } else if (el.emoji) {
        // Bonus: emoji in green box
        ctx.font = `${el.height * 0.7}px Arial`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(el.emoji, el.x + el.width / 2, el.y + el.height / 2);
      }
    } else {
      // Emoji only (links)
      ctx.font = `${el.width}px Arial`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(el.emoji!, el.x + el.width / 2, el.y + el.height / 2);
    }
  }

  function drawNet() {
    const netLeft = netX - NET_WIDTH / 2;

    // Net shape
    ctx.fillStyle = 'rgba(76, 117, 255, 0.3)';
    ctx.strokeStyle = '#4C75FF';
    ctx.lineWidth = 3;

    // Triangle/trapezoid net
    ctx.beginPath();
    ctx.moveTo(netLeft, NET_Y);
    ctx.lineTo(netLeft + NET_WIDTH, NET_Y);
    ctx.lineTo(netLeft + NET_WIDTH * 0.8, NET_Y + NET_HEIGHT);
    ctx.lineTo(netLeft + NET_WIDTH * 0.2, NET_Y + NET_HEIGHT);
    ctx.closePath();
    ctx.fill();
    ctx.stroke();

    // Handle
    ctx.strokeStyle = '#4C75FF';
    ctx.lineWidth = 4;
    ctx.beginPath();
    ctx.moveTo(netX, NET_Y + NET_HEIGHT);
    ctx.lineTo(netX, canvas.height);
    ctx.stroke();
  }

  function showScorePopup(x: number, y: number, points: number) {
    const popup = document.createElement('div');
    popup.className = `score-popup ${points > 0 ? 'positive' : 'negative'}`;
    popup.textContent = points > 0 ? `+${points}` : `${points}`;

    const rect = canvas.getBoundingClientRect();
    const scaleX = rect.width / canvas.width;
    const scaleY = rect.height / canvas.height;

    popup.style.left = `${x * scaleX}px`;
    popup.style.top = `${y * scaleY}px`;

    scorePopups.appendChild(popup);

    setTimeout(() => {
      popup.remove();
    }, 1000);
  }

  function loseLife() {
    lives--;
    updateUI();

    damageOverlay.classList.add('active');
    setTimeout(() => {
      damageOverlay.classList.remove('active');
    }, 500);

    if (lives <= 0) {
      endGame();
    }
  }

  function levelUp() {
    level++;
    speedMultiplier += 0.2;
    spawnInterval = Math.max(600, spawnInterval - 100);
    updateUI();
  }

  function updateUI() {
    scoreEl.textContent = score.toString();
    livesEl.textContent = '🔗'.repeat(Math.max(0, lives));
    levelEl.textContent = level.toString();
  }

  function endGame() {
    gameRunning = false;
    cancelAnimationFrame(animationId);
    finalScoreEl.textContent = score.toString();
    gameOverOverlay.classList.remove('hidden');
    loadLeaderboard();
  }

  // Mouse movement
  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    mouseX = (e.clientX - rect.left) * scaleX;
  });

  // Touch support
  canvas.addEventListener('touchmove', (e) => {
    e.preventDefault();
    const touch = e.touches[0];
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    mouseX = (touch.clientX - rect.left) * scaleX;
  }, { passive: false });

  startBtn.addEventListener('click', () => {
    startGame();
  });

  restartBtn.addEventListener('click', () => {
    init();
  });

  // Score submission
  scoreForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const usernameInput = document.getElementById('username') as HTMLInputElement;
    const username = usernameInput.value.trim();

    if (!username || username.length > 20 || !/^[a-zA-Z0-9_-]+$/.test(username)) {
      formError.textContent = 'Pseudo invalide (lettres, chiffres, - et _ uniquement, max 20 caractères)';
      formError.classList.remove('hidden');
      return;
    }

    try {
      const response = await fetch('/api/scores', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, score }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Erreur lors de l\'enregistrement');
      }

      formError.classList.add('hidden');
      usernameInput.value = '';
      scoreForm.style.display = 'none';
      loadLeaderboard();
    } catch (error) {
      formError.textContent = error instanceof Error ? error.message : 'Erreur réseau';
      formError.classList.remove('hidden');
    }
  });

  // Load leaderboard
  async function loadLeaderboard() {
    try {
      const response = await fetch('/api/scores');
      const data = await response.json();

      if (!data.scores || data.scores.length === 0) {
        leaderboardList.innerHTML = '<p class="loading">Aucun score enregistré</p>';
        return;
      }

      leaderboardList.innerHTML = data.scores.map((item: any, index: number) => {
        const isCurrentPlayer = item.score === score && !scoreForm.style.display;
        const date = new Date(item.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' });

        return `
          <div class="leaderboard-item ${isCurrentPlayer ? 'highlight' : ''}">
            <span class="leaderboard-rank">#${index + 1}</span>
            <span class="leaderboard-username">${escapeHtml(item.username)}</span>
            <span class="leaderboard-score">${item.score}</span>
            <span class="leaderboard-date">${date}</span>
          </div>
        `;
      }).join('');
    } catch (error) {
      leaderboardList.innerHTML = '<p class="loading">Erreur de chargement</p>';
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Initialize game
  init();
  loadLeaderboard();
</script>

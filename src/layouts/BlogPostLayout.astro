---
import BaseLayout from './BaseLayout.astro';
import { decodeHtml } from '../lib/html';
import { getPostPath } from '../lib/wordpress';

interface Props {
  post: any;
  readingTime: number;
  relatedPosts?: any[];
}

const { post, readingTime, relatedPosts = [] } = Astro.props;

const title = decodeHtml(post.title.rendered);
const description = post.excerpt.rendered.replace(/<[^>]*>/g, '').slice(0, 160);
const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
const category = post._embedded?.['wp:term']?.[0]?.[0];

function formatDate(dateString: string): string {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
}

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  datePublished: post.date,
  dateModified: post.modified || post.date,
  author: {
    '@type': 'Person',
    name: 'Anthony Russo',
    url: 'https://anthonyrusso.fr',
  },
  publisher: {
    '@type': 'Person',
    name: 'Anthony Russo',
  },
  image: featuredImage || 'https://anthonyrusso.fr/og-default.jpg',
  url: `https://anthonyrusso.fr${getPostPath(post)}`,
};
---

<BaseLayout title={title} description={description} ogImage={featuredImage} schema={schema}>
  <div class="blog-post-container">
    <article class="post-content">
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Accueil</a></li>
          <li><a href="/blog">Blog</a></li>
          <li aria-current="page">{title}</li>
        </ol>
      </nav>

      <!-- Post header -->
      <header class="post-header">
        {category && (
          <div class="post-meta-header">
            <span class="badge badge-success">{category.name}</span>
            <span class="reading-time">{readingTime} min de lecture</span>
          </div>
        )}

        <h1>{title}</h1>

        <div class="post-meta">
          <time datetime={post.date}>{formatDate(post.date)}</time>
          <span class="meta-separator">·</span>
          <span>Par Anthony Russo</span>
        </div>
      </header>

      <!-- Featured image -->
      {featuredImage && (
        <div class="featured-image">
          <img
            src={featuredImage}
            alt={post._embedded?.['wp:featuredmedia']?.[0]?.alt_text || title}
            loading="eager"
          />
        </div>
      )}

      <!-- Post content -->
      <div class="post-body prose" set:html={post.content.rendered} />

      <!-- Related posts -->
      {relatedPosts.length > 0 && (
        <section class="related-posts">
          <h2>Articles liés</h2>
          <div class="related-grid">
            {relatedPosts.map((related) => {
              const relatedImage = related._embedded?.['wp:featuredmedia']?.[0]?.source_url;
              const relatedCategory = related._embedded?.['wp:term']?.[0]?.[0];

              return (
                <article class="card related-card">
                  {relatedImage && (
                    <a href={getPostPath(related)} class="related-image">
                      <img
                        src={relatedImage}
                        alt={related.title.rendered}
                        loading="lazy"
                      />
                    </a>
                  )}
                  <div class="related-content">
                    {relatedCategory && (
                      <span class="badge badge-success badge-sm">{relatedCategory.name}</span>
                    )}
                    <h3 class="related-title">
                      <a href={getPostPath(related)}>
                        {decodeHtml(related.title.rendered)}
                      </a>
                    </h3>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      )}

      <!-- CTA final -->
      <section class="post-cta">
        <div class="cta-content">
          <h2>Vous voulez appliquer ça à votre site ?</h2>
          <p>
            Je vous aide à définir et exécuter votre stratégie netlinking sur-mesure.
          </p>
          <a
            href="https://calendly.com/anthony-russo-digital/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary btn-lg"
          >
            Réserver un audit netlinking →
          </a>
        </div>
      </section>
    </article>
  </div>
</BaseLayout>

<style>
  .blog-post-container {
    width: 100%;
    max-width: var(--max-width-lg);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) var(--space-4xl);
  }

  .post-content {
    width: 100%;
  }

  /* Breadcrumb */
  .breadcrumb {
    margin-bottom: var(--space-xl);
  }

  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .breadcrumb li:not(:last-child)::after {
    content: "→";
    margin-left: var(--space-sm);
    color: var(--color-text-faint);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .breadcrumb a:hover {
    color: var(--color-primary);
  }

  /* Post header */
  .post-header {
    margin-bottom: var(--space-2xl);
  }

  .post-meta-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .reading-time {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .post-header h1 {
    margin-bottom: var(--space-lg);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  .meta-separator {
    color: var(--color-text-faint);
  }

  /* Featured image */
  .featured-image {
    margin-bottom: var(--space-2xl);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .featured-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Post body (WordPress content) */
  .post-body {
    margin-bottom: var(--space-4xl);
  }

  /* Prose styles for WordPress content */
  .prose {
    color: var(--color-text);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .prose h2 {
    font-size: 1.75rem;
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
  }

  .prose h3 {
    font-size: 1.375rem;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .prose p {
    margin-bottom: var(--space-lg);
  }

  .prose ul,
  .prose ol {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
  }

  .prose li {
    margin-bottom: var(--space-sm);
  }

  .prose a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose a:hover {
    color: var(--color-primary-hover);
  }

  .prose strong {
    font-weight: 700;
    color: var(--color-text);
  }

  .prose img {
    border-radius: var(--radius-md);
    margin: var(--space-xl) 0;
  }

  .prose blockquote {
    border-left: 4px solid var(--color-primary);
    padding-left: var(--space-xl);
    margin: var(--space-xl) 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .prose code {
    background: var(--color-surface-2);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
    font-family: 'Courier New', monospace;
    word-break: break-word;
  }

  .prose pre {
    background: var(--color-surface-2);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin: var(--space-xl) 0;
  }

  .prose pre code {
    background: none;
    padding: 0;
    word-break: normal;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-xl) 0;
    overflow-x: auto;
    display: block;
  }

  .prose thead {
    display: table-header-group;
  }

  .prose tbody {
    display: table-row-group;
  }

  .prose tr {
    display: table-row;
  }

  .prose th,
  .prose td {
    display: table-cell;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .prose th {
    background: var(--color-surface-2);
    font-weight: 700;
  }

  /* Related posts */
  .related-posts {
    padding-top: var(--space-3xl);
    border-top: 2px solid var(--color-divider);
    margin-bottom: var(--space-3xl);
  }

  .related-posts h2 {
    font-size: 1.5rem;
    margin-bottom: var(--space-xl);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-xl);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .related-image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface-offset);
  }

  .related-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .related-card:hover .related-image img {
    transform: scale(1.05);
  }

  .related-content {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .related-title {
    font-size: 1rem;
    margin: 0;
    line-height: 1.4;
  }

  .related-title a {
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .related-title a:hover {
    color: var(--color-primary);
  }

  .badge-sm {
    font-size: 0.6875rem;
    padding: 2px var(--space-sm);
  }

  /* Post CTA */
  .post-cta {
    background: var(--color-surface-2);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-xl);
    padding: var(--space-3xl);
    text-align: center;
    box-shadow: var(--shadow-md), var(--glow-primary);
  }

  .cta-content h2 {
    font-size: 1.75rem;
    margin-bottom: var(--space-lg);
  }

  .cta-content p {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .blog-post-container {
      padding: var(--space-xl) var(--space-md) var(--space-3xl);
    }

    .prose {
      font-size: 1rem;
    }

    .prose h2 {
      font-size: 1.5rem;
      margin-top: var(--space-2xl);
    }

    .prose h3 {
      font-size: 1.25rem;
    }

    .prose table {
      font-size: 0.875rem;
    }

    .prose th,
    .prose td {
      padding: var(--space-xs) var(--space-sm);
    }

    .post-cta {
      padding: var(--space-2xl) var(--space-lg);
    }

    .cta-content h2 {
      font-size: 1.5rem;
    }

    .cta-content p {
      font-size: 1rem;
    }
  }

  @media (max-width: 640px) {
    .breadcrumb ol {
      font-size: 0.8125rem;
    }

    .featured-image {
      margin-bottom: var(--space-xl);
      border-radius: var(--radius-md);
    }

    .related-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
